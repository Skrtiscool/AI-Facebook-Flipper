generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                 @id @default(cuid())
  email                String                 @unique
  name                 String?
  imageUrl             String?
  clerkId              String                 @unique
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  deals                Deal[]
  savedSearches        SavedSearch[]
  subscription         Subscription?
  alerts               Alert[]
  notificationChannels NotificationChannel[]
}

model Deal {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  alertId        String?
  alert          Alert?   @relation(fields: [alertId], references: [id])
  title          String
  description    String?
  price          Float
  estimatedValue Float
  profit         Float
  score          Int
  recommendation String
  reason         String?
  confidence     Float    @default(0)
  platform       String?
  listingUrl     String?
  imageUrls      String[]
  brand          String?
  condition      String?
  location       String?
  scannedAt      DateTime @default(now())
  read           Boolean  @default(false)
  saved          Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  notes          String?
  category       String?
  status         String   @default("watching")
  shippingCost   Float?
  fees           Float?
  actualProfit   Float?
  messagedAt     DateTime?
  lastSeenPrice  Float?
  priceHistory   Json?
  scanCount      Int      @default(1)
  lastPriceDrop  DateTime?
  priceChanges   PriceChange[]
}

model PriceChange {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  oldPrice  Float
  newPrice  Float
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Alert {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  name       String
  keywords   String[]
  brands     String[]
  maxPrice   Float?
  minProfit  Float?
  minScore   Int?
  platforms  String[] @default(["facebook"])
  active     Boolean  @default(true)
  lastRunAt  DateTime?
  scanInterval Int?   @default(30)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deals      Deal[]
}

model ScannerRun {
  id              String      @id @default(cuid())
  startedAt       DateTime    @default(now())
  completedAt     DateTime?
  listingsScanned Int         @default(0)
  dealsFound      Int         @default(0)
  status          String      @default("running")
  error           String?
  triggeredBy     String      @default("scheduler")
  alertId         String?
}

model NotificationChannel {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   @default("discord")
  config    String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  query     String
  filters   String?
  createdAt DateTime @default(now())
}

model Subscription {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  plan          String
  status        String
  stripeId      String?
  currentPeriod DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
