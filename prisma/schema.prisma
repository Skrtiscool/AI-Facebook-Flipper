generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                 @id @default(cuid())
  email                String                 @unique
  name                 String?
  imageUrl             String?
  clerkId              String                 @unique
  stripeCustomerId     String?
  scanCountThisMonth   Int                    @default(0)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  deals                Deal[]
  savedSearches        SavedSearch[]
  subscription         Subscription?
  alerts               Alert[]
  notificationChannels NotificationChannel[]
}

model Deal {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  alertId        String?
  alert          Alert?   @relation(fields: [alertId], references: [id])
  title          String
  description    String?
  price          Float
  estimatedValue Float
  profit         Float
  score          Int
  recommendation String
  reason         String?
  confidence     Float    @default(0)
  platform       String?
  listingUrl     String?
  imageUrls      String[]
  brand          String?
  condition      String?
  location       String?
  scannedAt      DateTime @default(now())
  read           Boolean  @default(false)
  saved          Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  notes          String?
  category       String?
  status         String   @default("watching")
  shippingCost   Float?
  fees           Float?
  actualProfit   Float?
  messagedAt     DateTime?
  lastSeenPrice  Float?
  priceHistory   Json?
  scanCount      Int      @default(1)
  lastPriceDrop  DateTime?
  priceChanges   PriceChange[]

  offerAmount     Float?
  offerDate       DateTime?
  sellerResponse  String?
  expectedSalePrice Float?
  dateBought      DateTime?
  dateSold        DateTime?
  storageLocation String?
  costBasis       Float?
  roi             Float?
  daysInInventory Int?

  dealTags   DealTag[]
  activities DealActivity[]
}

model Tag {
  id        String    @id @default(cuid())
  name      String
  color     String    @default("#6366f1")
  userId    String
  dealTags  DealTag[]
  createdAt DateTime  @default(now())
}

model DealTag {
  dealId String
  tagId  String
  deal   Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([dealId, tagId])
}

model DealActivity {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  type      String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())
}

model SavedFilter {
  id        String   @id @default(cuid())
  userId    String
  name      String
  filters   String
  createdAt DateTime @default(now())
}

model PriceChange {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  oldPrice  Float
  newPrice  Float
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Alert {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  name       String
  keywords   String[]
  brands     String[]
  maxPrice   Float?
  minProfit  Float?
  minScore   Int?
  platforms  String[] @default(["facebook"])
  active     Boolean  @default(true)
  lastRunAt  DateTime?
  scanInterval Int?   @default(30)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deals      Deal[]
}

model ScannerRun {
  id              String      @id @default(cuid())
  userId          String?
  startedAt       DateTime    @default(now())
  completedAt     DateTime?
  listingsScanned Int         @default(0)
  dealsFound      Int         @default(0)
  status          String      @default("running")
  error           String?
  triggeredBy     String      @default("scheduler")
  alertId         String?
}

model NotificationChannel {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   @default("discord")
  config    String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  query     String
  filters   String?
  createdAt DateTime @default(now())
}

model Subscription {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  plan             String
  status           String
  stripeId         String?
  stripeCustomerId String?
  currentPeriod    DateTime?
  cancelAtPeriodEnd Boolean @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
